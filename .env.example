# --- Database (Neon Postgres, or any Postgres-compatible host) ---
# When you create a Neon database from Vercel's Storage tab, this is
# injected automatically — you shouldn't need to set it by hand there.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- Auth ---
# Any long random string. Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_a_long_random_string

# --- OTP delivery (Twilio Verify) ---
# Leave these blank to run in DEMO MODE: OTP codes are stored in the DB
# and printed to the server log instead of being texted out. Good for
# local testing, but set these before going live.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- App rules ---
# Days that must pass since a donor's last donation before they count as active
DONOR_ELIGIBILITY_DAYS=90
# Max distance (km) to search for donors around a patient request
MATCH_RADIUS_KM=50
# Max number of donors to notify per request
MATCH_LIMIT=15
